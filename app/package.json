{
  "name": "agencyflow",
  "version": "1.0.0",
  "description": "Plataforma de produtividade para agências de marketing digital",
  "private": true,
  "scripts": {
    "start": "npx serve .",
    "dev": "npx serve . -l 3000",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.js",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "lint": "npx eslint src/ || true",
    "security-audit": "npx npm audit || true"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^24.0.0",
    "eslint": "^8.56.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
